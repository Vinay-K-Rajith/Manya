{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  // Netlify entrypoint from an earlier deploy attempt. Deployment is on Vercel via
  // api/index.ts, and this file's serverless-http dependency is not installed.
  "exclude": ["src/netlify-function.ts"]
}

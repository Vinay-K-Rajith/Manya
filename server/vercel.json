{
  "installCommand": "cd .. && npm install",
  "buildCommand": "cd .. && npm run build:client",
  "outputDirectory": "../client/dist",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
